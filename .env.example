# LLM provider selection: bedrock, openai, gemini, fake
OMA_LLM_PROVIDER=fake

# AWS Bedrock configuration
AWS_PROFILE=default
AWS_REGION=us-west-2
BEDROCK_MODEL_ID=example-bedrock-model

# Image generation provider: fake, bedrock, openai, gemini
OKA_IMAGE_PROVIDER=fake
OKA_IMAGE_MODEL=stability.sd3-5-large-v1:0
OKA_IMAGE_AWS_REGION=us-west-2
OKA_IMAGE_SIZE=1536x1024

# OpenAI configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=gpt-image-2

# Gemini configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_IMAGE_MODEL=gemini-3.1-flash-lite-image
