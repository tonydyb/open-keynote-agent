# LLM provider selection: bedrock, openai, gemini, fake
OMA_LLM_PROVIDER=fake

# AWS Bedrock configuration
AWS_PROFILE=default
AWS_REGION=us-west-2
BEDROCK_MODEL_ID=example-bedrock-model

# OpenAI configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Gemini configuration
GEMINI_API_KEY=
GEMINI_MODEL=projects/your-project/locations/us-central1/models/chat-bison-001
