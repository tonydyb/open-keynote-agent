{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "OKA: version",
      "type": "debugpy",
      "request": "launch",
      "module": "open_keynote_agent.cli",
      "args": ["version"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "python": "${workspaceFolder}/.venv/bin/python",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "OKA: organize dry-run",
      "type": "debugpy",
      "request": "launch",
      "module": "open_keynote_agent.cli",
      // "args": ["organize", "${workspaceFolder}/demo", "--dry-run"],
      "args": ["organize", "/Users/youbingding/Downloads/tmp", "--dry-run"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "python": "${workspaceFolder}/.venv/bin/python",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "OKA: ask dry-run",
      "type": "debugpy",
      "request": "launch",
      "module": "open_keynote_agent.cli",
      "args": ["ask", "Organize /Users/youbingding/Downloads/tmp into PDFs, Images and Documents"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "python": "${workspaceFolder}/.venv/bin/python",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "OKA: session",
      "type": "debugpy",
      "request": "launch",
      "module": "open_keynote_agent.cli",
      "args": ["session"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "python": "${workspaceFolder}/.venv/bin/python",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "OKA: session no-confirm",
      "type": "debugpy",
      "request": "launch",
      "module": "open_keynote_agent.cli",
      "args": ["session", "--no-confirm"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "python": "${workspaceFolder}/.venv/bin/python",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "OKA: session keynote",
      "type": "debugpy",
      "request": "launch",
      "module": "open_keynote_agent.cli",
      "args": ["session", "--tools", "keynote"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "python": "${workspaceFolder}/.venv/bin/python",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "OKA: session keynote no-confirm",
      "type": "debugpy",
      "request": "launch",
      "module": "open_keynote_agent.cli",
      "args": ["session", "--tools", "keynote", "--no-confirm"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "python": "${workspaceFolder}/.venv/bin/python",
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
